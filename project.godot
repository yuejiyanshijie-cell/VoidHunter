; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Void Hunter"
config/description="A 2D action platformer demo set in ancient alien ruins."
config/version="0.1.0"
config/tags=PackedStringArray("2d", "action", "platformer", "pixel_art")
run/main_scene="res://scenes/main_level.tscn"
config/features=PackedStringArray("4.7")

[autoload]

EventBus="*res://scripts/cs/EventBus.cs"
GameManager="*res://scripts/cs/GameManager.cs"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="canvas_items"

